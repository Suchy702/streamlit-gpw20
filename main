#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
PID_FILE="$ROOT_DIR/.streamlit.pid"
LOG_FILE="$ROOT_DIR/.streamlit.log"
PORT="8501"
APP_FILE="streamlit_app.py"

usage() {
	echo "Uzycie: ./main {up|down}"
}

is_running() {
	local pid="$1"
	kill -0 "$pid" 2>/dev/null
}

start_app() {
	if [[ ! -d "$ROOT_DIR/.venv" ]]; then
		echo "Brak .venv. Utworz je i zainstaluj zaleznosci przed uruchomieniem."
		exit 1
	fi

	if [[ -f "$PID_FILE" ]]; then
		old_pid="$(cat "$PID_FILE")"
		if [[ -n "$old_pid" ]] && is_running "$old_pid"; then
			echo "Aplikacja juz dziala (PID: $old_pid)."
			echo "URL: http://localhost:$PORT"
			exit 0
		fi
		rm -f "$PID_FILE"
	fi

	if command -v fuser >/dev/null 2>&1 && fuser "$PORT/tcp" >/dev/null 2>&1; then
		echo "Port $PORT jest zajety. Zwolnij port albo uruchom ./main down."
		exit 1
	fi

	cd "$ROOT_DIR"
	source "$ROOT_DIR/.venv/bin/activate"
	nohup streamlit run "$APP_FILE" --server.headless true --server.port "$PORT" >"$LOG_FILE" 2>&1 &
	new_pid="$!"
	echo "$new_pid" >"$PID_FILE"

	sleep 2
	if is_running "$new_pid"; then
		echo "Uruchomiono Streamlit (PID: $new_pid)."
		echo "URL: http://localhost:$PORT"
		echo "Log: $LOG_FILE"
	else
		echo "Nie udalo sie uruchomic aplikacji. Szczegoly w logu: $LOG_FILE"
		exit 1
	fi
}

stop_app() {
	if [[ -f "$PID_FILE" ]]; then
		pid="$(cat "$PID_FILE")"
		if [[ -n "$pid" ]] && is_running "$pid"; then
			kill "$pid" 2>/dev/null || true
			for _ in {1..20}; do
				if ! is_running "$pid"; then
					break
				fi
				sleep 0.2
			done
			if is_running "$pid"; then
				kill -9 "$pid" 2>/dev/null || true
			fi
		fi
		rm -f "$PID_FILE"
	fi

	if command -v fuser >/dev/null 2>&1; then
		fuser -k "$PORT/tcp" >/dev/null 2>&1 || true
	fi

	echo "Zatrzymano Streamlit na porcie $PORT."
}

if [[ $# -ne 1 ]]; then
	usage
	exit 1
fi

case "$1" in
	up)
		start_app
		;;
	down)
		stop_app
		;;
	*)
		usage
		exit 1
		;;
esac
